{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://replace-with-full-backend.example.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/static/app.js"
    },
    {
      "source": "/style.css",
      "destination": "/static/style.css"
    },
    {
      "source": "/:path*",
      "destination": "/static/:path*"
    }
  ]
}
